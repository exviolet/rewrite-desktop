{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:scope-home-recursive",
    "fs:scope-desktop-recursive",
    "fs:scope-document-recursive",
    "fs:scope-download-recursive",
    "fs:scope-temp-recursive",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "tmux",
          "cmd": "tmux",
          "args": true
        },
        {
          "name": "orca-terminal-send-text",
          "cmd": "orca-ide",
          "args": ["terminal", "send", "--terminal", { "validator": "^term_[0-9a-fA-F-]+$" }, "--text", { "validator": "^[\\s\\S]*$" }, "--json"]
        },
        {
          "name": "orca-terminal-send-enter",
          "cmd": "orca-ide",
          "args": ["terminal", "send", "--terminal", { "validator": "^term_[0-9a-fA-F-]+$" }, "--enter", "--json"]
        },
        {
          "name": "orca-worktree-ps",
          "cmd": "orca-ide",
          "args": ["worktree", "ps", "--json"]
        },
        {
          "name": "orca-terminal-list",
          "cmd": "orca-ide",
          "args": ["terminal", "list", "--json"]
        },
        {
          "name": "orca-terminal-wait",
          "cmd": "orca-ide",
          "args": ["terminal", "wait", "--terminal", { "validator": "^term_[0-9a-fA-F-]+$" }, "--for", "tui-idle", "--timeout-ms", { "validator": "^[0-9]+$" }, "--json"]
        }
      ]
    },
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-theme"
  ]
}
