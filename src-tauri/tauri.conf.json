{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RewriteBox",
  "version": "0.1.0",
  "identifier": "com.rewritebox.app",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd web && bun install && bun dev --port 1420",
    "beforeBuildCommand": "cd web && bun install && bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "RewriteBox",
        "decorations": false,
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
